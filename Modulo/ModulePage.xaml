<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Modulo.ModulePage"
             Title="Module Overview">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="30">

            <!-- 🔹 Module Header -->
            <VerticalStackLayout Spacing="5">
                <Label Text="HTML and CSS" FontSize="28" FontAttributes="Bold" TextColor="Black"/>
                <Label Text="Progress: 3 of 10 lessons completed" FontSize="16" TextColor="Gray" />
            </VerticalStackLayout>

            <!-- 🔸 Lesson Section: Basics -->
            <Label Text="Basic HTML" FontSize="20" FontAttributes="Bold" TextColor="Black"/>
            <ScrollView Orientation="Horizontal">
                <HorizontalStackLayout Spacing="15">
                    <Frame WidthRequest="150" HeightRequest="150" BackgroundColor="#e0f7fa" CornerRadius="10" Padding="10">
                        <VerticalStackLayout>
                            <Label Text="Lesson 1" FontSize="18" FontAttributes="Bold" TextColor="Black"/>
                            <Label Text="Intro to Sorting" FontSize="14" TextColor="Black"/>
                            <ProgressBar Progress="0.5" HeightRequest="6" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame WidthRequest="150" HeightRequest="150" BackgroundColor="#e0f7fa" CornerRadius="10" Padding="10">
                        <VerticalStackLayout>
                            <Label Text="Lesson 2" FontSize="18" FontAttributes="Bold" TextColor="Black"/>
                            <Label Text="Bubble Sort" FontSize="14" TextColor="Black"/>
                            <ProgressBar Progress="0.0" HeightRequest="6" />
                        </VerticalStackLayout>
                    </Frame>
                    <!-- Add more lessons -->
                </HorizontalStackLayout>
            </ScrollView>

            <!-- 🔸 Lesson Section: Intermediate -->
            <Label Text="Accessibility" FontSize="20" FontAttributes="Bold" TextColor="Black"/>
            <ScrollView Orientation="Horizontal">
                <HorizontalStackLayout Spacing="15">
                    <Frame WidthRequest="150" HeightRequest="150" BackgroundColor="#fce4ec" CornerRadius="10" Padding="10">
                        <VerticalStackLayout>
                            <Label Text="Lesson 3" FontSize="18" FontAttributes="Bold" TextColor="Black"/>
                            <Label Text="Merge Sort" FontSize="14" TextColor="Black"/>
                            <ProgressBar Progress="0.0" HeightRequest="6" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame WidthRequest="150" HeightRequest="150" BackgroundColor="#fce4ec" CornerRadius="10" Padding="10">
                        <VerticalStackLayout>
                            <Label Text="Lesson 4" FontSize="18" FontAttributes="Bold" TextColor="Black"/>
                            <Label Text="Quick Sort" FontSize="14" TextColor="Black"/>
                            <ProgressBar Progress="0.0" HeightRequest="6" />
                        </VerticalStackLayout>
                    </Frame>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- 🔸 Lesson Section: Advanced -->
            <Label Text="Properties" FontSize="20" FontAttributes="Bold" TextColor="Black"/>
            <ScrollView Orientation="Horizontal">
                <HorizontalStackLayout Spacing="15">
                    <Frame WidthRequest="150" HeightRequest="150" BackgroundColor="#ede7f6" CornerRadius="10" Padding="10">
                        <VerticalStackLayout>
                            <Label Text="Lesson 5" FontSize="18" FontAttributes="Bold" TextColor="Black"/>
                            <Label Text="Heap Sort" FontSize="14" TextColor="Black"/>
                            <ProgressBar Progress="0.0" HeightRequest="6" />
                        </VerticalStackLayout>
                    </Frame>
                    <!-- Add more advanced lessons -->
                </HorizontalStackLayout>
            </ScrollView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
